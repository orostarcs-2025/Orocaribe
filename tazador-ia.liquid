<script>
// Variables globales
let imagenEscaneoBase64 = null;
let imagenEscaneoMime = 'image/jpeg';

function getSectionData() {
  var sec = document.getElementById('orocaribe-tazador');
  if (!sec) return { apiKey: '', whatsapp: '18495071819' };
  return {
    apiKey: (sec.getAttribute('data-api-key') || '').trim(),
    whatsapp: (sec.getAttribute('data-whatsapp') || '18495071819').trim()
  };
}

function setScanImage(file) {
  if (!file || !file.type.startsWith('image/')) return;
  imagenEscaneoMime = file.type;
  var reader = new FileReader();
  reader.onload = function(e) {
    imagenEscaneoBase64 = e.target.result.split(',')[1];
    document.getElementById('scanPreviewImg').src = e.target.result;
    document.getElementById('scanPreview').classList.add('visible');
    var data = getSectionData();
    document.getElementById('analyzeBtn').disabled = !data.apiKey;
  };
  reader.readAsDataURL(file);
}

document.getElementById('scanFile').onchange = function() { setScanImage(this.files[0]); };
document.getElementById('scanCamera').onchange = function() { setScanImage(this.files[0]); };

function normalizeQuilates(val) {
  if (!val) return '';
  var v = (val + '').toLowerCase().replace(/\s/g, ' ');
  var map = { '10k': '10k', '14k nacional': '14k Nacional', '14k italiano': '14k Italiano', '18k nacional': '18k Nacional', '18k italiano': '18k Italiano', '22k': '22k', '24k': '24k' };
  return map[v] || val;
}

function normalizeEstado(val) {
  if (!val) return '';
  var v = (val + '').toLowerCase();
  var opts = ['Nuevo', 'Excelente', 'Bueno', 'Regular', 'Para fundir'];
  for (var i = 0; i < opts.length; i++) {
    if (opts[i].toLowerCase() === v) return opts[i];
  }
  if (/excelente/i.test(v)) return 'Excelente';
  if (/bueno/i.test(v)) return 'Bueno';
  if (/regular/i.test(v)) return 'Regular';
  if (/fundir/i.test(v)) return 'Para fundir';
  if (/nuevo/i.test(v)) return 'Nuevo';
  return val;
}

function normalizeTipoJoya(val) {
  if (!val) return '';
  var v = (val + '').toLowerCase();
  var opts = ['Anillo', 'Cadena', 'Pulsera', 'Aretes', 'Dije', 'Reloj', 'Otro'];
  for (var i = 0; i < opts.length; i++) {
    if (opts[i].toLowerCase() === v) return opts[i];
  }
  if (/anillo/i.test(v)) return 'Anillo';
  if (/cadena/i.test(v)) return 'Cadena';
  if (/pulsera/i.test(v)) return 'Pulsera';
  if (/arete/i.test(v)) return 'Aretes';
  if (/dije/i.test(v)) return 'Dije';
  if (/reloj/i.test(v)) return 'Reloj';
  return 'Otro';
}

function analizarConIA() {
  var data = getSectionData();
  if (!imagenEscaneoBase64 || !data.apiKey) return;
  document.getElementById('iaLoading').classList.add('visible');
  document.getElementById('analyzeBtn').disabled = true;
  var promptText = 'Eres un experto tasador de joyeria. Analiza la imagen y responde SOLO un JSON (sin markdown, sin texto extra) con estas claves: tipoJoya (Anillo, Cadena, Pulsera, Aretes, Dije, Reloj, Otro), colorMetal (Oro amarillo, Oro blanco, Oro rosa, Plata), quilates (10k, 14k Nacional, 14k Italiano, 18k Nacional, 18k Italiano, 22k, 24k), estado (Nuevo, Excelente, Bueno, Regular, Para fundir), descripcionBreve (frase corta). Analiza esta imagen y devuelve únicamente el JSON.';
  var body = {
    contents: [
      {
        parts: [
          { text: promptText },
          { inline_data: { mime_type: imagenEscaneoMime, data: imagenEscaneoBase64 } }
        ]
      }
    ],
    generation_config: { temperature: 0.2, max_output_tokens: 512 }
  };
  function llamarAPI(url) {
    return fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
      .then(function(res) {
        return res.text().then(function(txt) {
          var data;
          try { data = JSON.parse(txt); } catch (e) { return Promise.reject(new Error('Respuesta inválida')); }
          if (!res.ok) {
            var msg = (data.error && data.error.message) ? data.error.message : res.status + ' ' + res.statusText;
            return Promise.reject(new Error(msg));
          }
          if (data.error && data.error.message) return Promise.reject(new Error(data.error.message));
          return data;
        });
      });
  }
  function procesarRespuesta(data) {
    var text = data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts && data.candidates[0].content.parts[0] ? data.candidates[0].content.parts[0].text : null;
    if (!text) throw new Error('La IA no devolvió texto.');
    var json = {};
    try { json = JSON.parse(text.trim()); } catch (e) {
      var m = text.match(/\{[\s\S]*\}/);
      if (m) json = JSON.parse(m[0]);
    }
    var tipoJoya = normalizeTipoJoya(json.tipoJoya);
    var estado = normalizeEstado(json.estado);
    var kilates = normalizeQuilates(json.quilates);
    var desc = (json.descripcionBreve || '') + (json.colorMetal ? ' | ' + json.colorMetal : '');
    if (tipoJoya) document.getElementById('tipoJoya').value = tipoJoya;
    if (estado) document.getElementById('estado').value = estado;
    if (kilates) document.getElementById('kilates').value = kilates;
    if (desc) document.getElementById('descripcion').value = desc.trim();
    var badge = document.getElementById('iaBadge');
    if (badge) badge.style.display = 'inline-block';
  }
  var url1 = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=' + encodeURIComponent(data.apiKey);
  var url2 = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash-8b:generateContent?key=' + encodeURIComponent(data.apiKey);
  llamarAPI(url1)
    .then(procesarRespuesta)
    .catch(function(err) {
      var msg = err && err.message ? err.message : '';
      if (msg.indexOf('not found') !== -1 || msg.indexOf('quota') !== -1 || msg.indexOf('429') !== -1) {
        return llamarAPI(url2).then(procesarRespuesta);
      }
      throw err;
    })
    .catch(function(err) {
      console.error('Error tasador IA:', err);
      var msg = err && err.message ? err.message : 'Error desconocido';
      if (msg.indexOf('Failed to fetch') !== -1 || msg.indexOf('NetworkError') !== -1) {
        msg = 'Error de red o CORS. La API de Google Gemini puede no permitir llamadas desde el navegador.';
      }
      alert('No se pudo analizar la imagen.\n\n' + msg + '\n\nPuedes llenar el formulario manualmente.');
    })
    .finally(function() {
      document.getElementById('iaLoading').classList.remove('visible');
      document.getElementById('analyzeBtn').disabled = false;
    });
}

document.getElementById('analyzeBtn').onclick = analizarConIA;

function enviarTasacion(e) {
  e.preventDefault();
  var data = getSectionData();
  var nombre = (document.getElementById('nombres').value + ' ' + document.getElementById('apellidos').value).trim();
  var tipo = document.getElementById('tipoJoya').value || 'No indicado';
  var metal = (document.getElementById('descripcion').value || 'No indicado').replace(/\n/g, ' ');
  var quilates = document.getElementById('kilates').value || 'No indicado';
  var estado = document.getElementById('estado').value || 'No indicado';
  var peso = document.getElementById('gramos').value || '—';
  var msg = 'Hola Oro Caribe, mi nombre es ' + nombre + '. Me gustaría tasar una joya con las siguientes características detectadas por su IA:\n\n';
  msg += 'Tipo: ' + tipo + '\n\n';
  msg += 'Metal: ' + metal + '\n\n';
  msg += 'Quilates: ' + quilates + '\n\n';
  msg += 'Estado: ' + estado + '\n\n';
  msg += 'Peso estimado: ' + peso + ' g\n\n';
  msg += '¿Podrían darme una valoración preliminar?\n\n';
  if (imagenEscaneoBase64) {
    msg += '📎 *Envío la foto de mi joya en el siguiente mensaje.*';
  }
  var waUrl = 'https://api.whatsapp.com/send/?phone=' + data.whatsapp + '&text=' + encodeURIComponent(msg) + '&type=phone_number&app_absent=0';
  window.open(waUrl, '_blank');
  if (imagenEscaneoBase64) {

<script>
// ── Estado global ─────────────────────────────────────────────────────────────
var imagenEscaneoBase64 = null;
var imagenEscaneoMime   = 'image/jpeg';

// ── Modelos Gemini actuales (orden de preferencia) ────────────────────────────
// gemini-1.5-flash-8b fue retirado; usar solo estos:
var MODELOS = [
  'gemini-2.0-flash',
  'gemini-1.5-flash'
];

function getSectionData() {
  var sec = document.getElementById('orocaribe-tazador');
  if (!sec) return { apiKey: '', whatsapp: '18495071819' };
  return {
    apiKey:    (sec.getAttribute('data-api-key')  || '').trim(),
    whatsapp:  (sec.getAttribute('data-whatsapp') || '18495071819').trim()
  };
}

// ── Imagen ────────────────────────────────────────────────────────────────────
function setScanImage(file) {
  if (!file || !file.type.startsWith('image/')) return;
  imagenEscaneoMime = file.type;
  var reader = new FileReader();
  reader.onload = function(e) {
    imagenEscaneoBase64 = e.target.result.split(',')[1];
    document.getElementById('scanPreviewImg').src = e.target.result;
    document.getElementById('scanPreview').classList.add('visible');
    document.getElementById('analyzeBtn').disabled = !getSectionData().apiKey;
  };
  reader.readAsDataURL(file);
}

document.getElementById('scanFile').onchange   = function() { setScanImage(this.files[0]); };
document.getElementById('scanCamera').onchange = function() { setScanImage(this.files[0]); };

// ── Normalización ─────────────────────────────────────────────────────────────
function normalizeQuilates(val) {
  if (!val) return '';
  var v = (val + '').toLowerCase().replace(/\s+/g, ' ').trim();
  var map = {
    '10k': '10k', '10 k': '10k',
    '14k nacional': '14k Nacional', '14k italiano': '14k Italiano',
    '18k nacional': '18k Nacional', '18k italiano': '18k Italiano', '750': '18k Italiano',
    '22k': '22k', '24k': '24k'
  };
  return map[v] || val;
}

function normalizeEstado(val) {
  if (!val) return '';
  var v = (val + '').toLowerCase();
  if (/excelente|excellent/i.test(v)) return 'Excelente';
  if (/bueno|good/i.test(v))          return 'Bueno';
  if (/regular/i.test(v))             return 'Regular';
  if (/fundir|fundicion/i.test(v))    return 'Para fundir';
  if (/nuevo|new/i.test(v))           return 'Nuevo';
  return val;
}

function normalizeTipoJoya(val) {
  if (!val) return '';
  var v = (val + '').toLowerCase();
  if (/anillo|ring/i.test(v))              return 'Anillo';
  if (/cadena|chain/i.test(v))             return 'Cadena';
  if (/pulsera|bracelet/i.test(v))         return 'Pulsera';
  if (/arete|aretes|pendiente|earring/i.test(v)) return 'Aretes';
  if (/dije|charm|pendant/i.test(v))       return 'Dije';
  if (/reloj|watch/i.test(v))              return 'Reloj';
  return 'Otro';
}

// ── Llamada a Gemini (directo desde navegador) ────────────────────────────────
var PROMPT_IA = [
  'Eres un experto tasador de joyería para Oro Caribe (República Dominicana).',
  'Analiza la imagen y responde ÚNICAMENTE con un JSON válido, sin markdown ni texto adicional.',
  'Claves requeridas:',
  '  tipoJoya          — Anillo, Cadena, Pulsera, Aretes, Dije, Reloj u Otro',
  '  colorMetal        — Oro amarillo, Oro blanco, Oro rosa, Plata u Otro',
  '  quilates          — 10k, 14k Nacional, 14k Italiano, 18k Nacional, 18k Italiano, 22k o 24k',
  '  estado            — Nuevo, Excelente, Bueno, Regular o Para fundir',
  '  desperfectos      — daños visibles o "Ninguno visible"',
  '  descripcionPedreria — piedras o decoraciones visibles o "Sin pedrería"',
  '  descripcionBreve  — una frase descriptiva de la pieza',
  'Devuelve SOLO el objeto JSON.'
].join('\n');

function llamarGemini(apiKey, modelo) {
  var url = 'https://generativelanguage.googleapis.com/v1beta/models/' +
            modelo + ':generateContent?key=' + encodeURIComponent(apiKey);
  var body = {
    contents: [{
      parts: [
        { text: PROMPT_IA },
        { inline_data: { mime_type: imagenEscaneoMime, data: imagenEscaneoBase64 } }
      ]
    }],
    generation_config: { temperature: 0.2, max_output_tokens: 600 }
  };
  return fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  }).then(function(res) {
    return res.text().then(function(txt) {
      var d;
      try { d = JSON.parse(txt); } catch(e) { throw new Error('Respuesta inválida del servidor'); }
      if (!res.ok) {
        var msg = (d.error && d.error.message) ? d.error.message : (res.status + ' ' + res.statusText);
        throw new Error(msg);
      }
      if (d.error && d.error.message) throw new Error(d.error.message);
      return d;
    });
  });
}

// Intenta modelos en orden hasta que uno funcione
function llamarConFallback(apiKey, modelos, indice) {
  indice = indice || 0;
  if (indice >= modelos.length) return Promise.reject(new Error('Todos los modelos fallaron.'));
  return llamarGemini(apiKey, modelos[indice]).catch(function(err) {
    var msg = err && err.message ? err.message : '';
    // Reintentar si el modelo no está disponible o hay cuota agotada
    if (/not found|quota|429|unavailable|deprecated/i.test(msg)) {
      return llamarConFallback(apiKey, modelos, indice + 1);
    }
    throw err;
  });
}

function procesarRespuestaIA(data) {
  var text = data.candidates &&
             data.candidates[0] &&
             data.candidates[0].content &&
             data.candidates[0].content.parts &&
             data.candidates[0].content.parts[0]
             ? data.candidates[0].content.parts[0].text : null;
  if (!text) throw new Error('La IA no devolvió texto.');

  var json = {};
  try { json = JSON.parse(text.trim()); }
  catch(e) {
    var m = text.match(/\{[\s\S]*\}/);
    if (m) json = JSON.parse(m[0]);
    else throw new Error('No se encontró JSON en la respuesta de la IA.');
  }

  // Auto-rellenar: tipo, descripción y estado (kilates lo elige el cliente)
  var tipoJoya = normalizeTipoJoya(json.tipoJoya);
  var estado   = normalizeEstado(json.estado);

  var partes = [];
  if (json.descripcionBreve) partes.push(json.descripcionBreve);
  if (json.colorMetal)       partes.push('Metal: ' + json.colorMetal);
  if (json.descripcionPedreria && json.descripcionPedreria !== 'Sin pedrería')
    partes.push('Pedrería: ' + json.descripcionPedreria);
  if (json.desperfectos && json.desperfectos !== 'Ninguno visible')
    partes.push('Desperfectos: ' + json.desperfectos);
  var desc = partes.join(' | ');

  if (tipoJoya) document.getElementById('tipoJoya').value   = tipoJoya;
  if (estado)   document.getElementById('estado').value     = estado;
  if (desc)     document.getElementById('descripcion').value = desc;

  var badge = document.getElementById('iaBadge');
  if (badge) badge.style.display = 'inline-block';
}

function analizarConIA() {
  var cfg = getSectionData();
  if (!imagenEscaneoBase64) return;
  if (!cfg.apiKey) {
    alert('Configura tu Google Gemini API Key en el atributo data-api-key de la sección.');
    return;
  }

  document.getElementById('iaLoading').classList.add('visible');
  document.getElementById('analyzeBtn').disabled = true;

  llamarConFallback(cfg.apiKey, MODELOS, 0)
    .then(procesarRespuestaIA)
    .catch(function(err) {
      console.error('Error tasador IA:', err);
      var msg = (err && err.message) ? err.message : 'Error desconocido';
      if (/Failed to fetch|NetworkError|CORS/i.test(msg)) {
        msg = 'Error de red. Verifica tu conexión a internet.';
      }
      alert('No se pudo analizar la imagen.\n\n' + msg + '\n\nPuedes completar el formulario manualmente.');
    })
    .finally(function() {
      document.getElementById('iaLoading').classList.remove('visible');
      document.getElementById('analyzeBtn').disabled = false;
    });
}

document.getElementById('analyzeBtn').onclick = analizarConIA;

// ── WhatsApp ──────────────────────────────────────────────────────────────────
function enviarTasacion(e) {
  e.preventDefault();
  var cfg     = getSectionData();
  var nombre  = (document.getElementById('nombres').value + ' ' + document.getElementById('apellidos').value).trim();
  var tipoId  = document.getElementById('tipoId').value;
  var idNum   = document.getElementById('identificacion').value;
  var tel     = document.getElementById('telefono').value;
  var correo  = document.getElementById('correo').value;
  var ciudad  = document.getElementById('ciudad').value;
  var tipo    = document.getElementById('tipoJoya').value    || 'No indicado';
  var desc    = (document.getElementById('descripcion').value || 'No indicada').replace(/\n/g, ' ');
  var estado  = document.getElementById('estado').value      || 'No indicado';
  var kilates = document.getElementById('kilates').value     || 'No indicado';
  var gramos  = document.getElementById('gramos').value      || '—';
  var precio  = document.getElementById('precioEsperado').value || 'No indicado';

  var msg = '🏅 *TASACIÓN DE JOYA — ORO CARIBE*\n\n';
  msg += '📋 *DATOS DE CONTACTO*\n';
  msg += '• Nombre: ' + nombre + '\n';
  msg += '• ' + tipoId + ': ' + idNum + '\n';
  msg += '• Teléfono: ' + tel + '\n';
  msg += '• Correo: ' + correo + '\n';
  msg += '• Ciudad: ' + ciudad + '\n\n';
  msg += '💍 *ANÁLISIS DE LA JOYA (IA)*\n';
  msg += '• Tipo: ' + tipo + '\n';
  msg += '• Descripción/Pedrería: ' + desc + '\n';
  msg += '• Estado: ' + estado + '\n\n';
  msg += '⚖️ *DATOS DE PESO Y CALIDAD*\n';
  msg += '• Kilates: ' + kilates + '\n';
  msg += '• Gramos: ' + gramos + ' g\n';
  msg += '• Precio esperado: ' + precio + '\n\n';
  msg += imagenEscaneoBase64
    ? '📎 _Envío la foto de mi joya en el siguiente mensaje._'
    : '¿Podrían confirmar la cotización? Los espero en su local.';

  var waUrl = 'https://api.whatsapp.com/send/?phone=' + cfg.whatsapp +
              '&text=' + encodeURIComponent(msg) +
              '&type=phone_number&app_absent=0';
  window.open(waUrl, '_blank');

  if (imagenEscaneoBase64) {
    alert('WhatsApp abierto con tu tasación. Adjunta la foto de tu joya presionando el ícono 📎 antes de enviar.');
  }
}
</script>

<!-- FORMULARIO TASADOR IA - ORO CARIBE -->

<style>
  .orocaribe-form * {
    box-sizing: border-box;
  }

  .orocaribe-form {
    padding: 60px 20px;
    background: #f8f9fa;
  }

  .orocaribe-form-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .form-card {
    background: white;
    border-radius: 12px;
    padding: 50px;
    box-shadow: 0 5px 30px rgba(0, 0, 0, 0.1);
  }

  .form-main-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #1a2942;
    text-align: center;
    margin-bottom: 10px;
  }

  .title-line {
    width: 80px;
    height: 4px;
    background: #daa520;
    margin: 0 auto 20px;
  }

  .form-subtitle {
    text-align: center;
    color: #666;
    margin-bottom: 30px;
    font-size: 1.1rem;
  }

  /* Escaneo de Joya */
  .scan-section {
    margin-bottom: 40px;
    padding: 30px;
    background: linear-gradient(135deg, rgba(26, 41, 66, 0.04) 0%, rgba(218, 165, 32, 0.06) 100%);
    border-radius: 12px;
    border: 2px dashed #daa520;
  }

  .scan-section-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a2942;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .scan-section-title svg {
    width: 28px;
    height: 28px;
    fill: #daa520;
  }

  .scan-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    align-items: center;
    margin-bottom: 20px;
  }

  .scan-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: linear-gradient(135deg, #daa520 0%, #f0c040 100%);
    border: none;
    border-radius: 10px;
    color: white;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(218, 165, 32, 0.3);
  }

  .scan-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(218, 165, 32, 0.4);
  }

  .scan-btn.secondary {
    background: linear-gradient(135deg, #1a2942 0%, #2c3e50 100%);
    box-shadow: 0 4px 15px rgba(26, 41, 66, 0.3);
  }

  .scan-btn.secondary:hover {
    box-shadow: 0 6px 20px rgba(26, 41, 66, 0.4);
  }

  .scan-btn svg {
    width: 22px;
    height: 22px;
    fill: white;
  }

  .scan-btn input[type="file"] {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    cursor: pointer;
  }

  .scan-preview-wrap {
    margin-top: 20px;
    text-align: center;
  }

  .scan-preview {
    max-width: 280px;
    max-height: 280px;
    margin: 0 auto 15px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
    display: none;
  }

  .scan-preview.visible {
    display: block;
  }

  .scan-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .analyze-btn {
    margin-top: 15px;
    padding: 16px 32px;
    background: linear-gradient(135deg, #1a2942 0%, #2c3e50 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 5px 20px rgba(26, 41, 66, 0.3);
  }

  .analyze-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(26, 41, 66, 0.4);
  }

  .analyze-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .ia-loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(26, 41, 66, 0.85);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    flex-direction: column;
    gap: 20px;
  }

  .ia-loading-overlay.visible {
    display: flex;
  }

  .ia-loading-spinner {
    width: 50px;
    height: 50px;
    border: 4px solid rgba(218, 165, 32, 0.3);
    border-top-color: #daa520;
    border-radius: 50%;
    animation: ia-spin 0.9s linear infinite;
  }

  .ia-loading-text {
    color: #fff;
    font-size: 1.2rem;
    font-weight: 600;
    text-align: center;
    padding: 0 20px;
  }

  @keyframes ia-spin {
    to { transform: rotate(360deg); }
  }

  .ia-filled-badge {
    display: inline-block;
    background: rgba(218, 165, 32, 0.2);
    color: #1a2942;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    margin-left: 8px;
  }

  .form-section {
    margin-bottom: 40px;
  }

  .section-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a2942;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f0f0f0;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-grid.full {
    grid-template-columns: 1fr;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: #333;
  }

  .form-input,
  .form-select,
  .form-textarea {
    padding: 14px 16px;
    border: 2px solid #e5e5e5;
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.3s;
    font-family: inherit;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #daa520;
    box-shadow: 0 0 0 3px rgba(218, 165, 32, 0.1);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .submit-button {
    width: 100%;
    padding: 18px;
    background: linear-gradient(135deg, #1a2942 0%, #2c3e50 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 20px;
    box-shadow: 0 5px 20px rgba(26, 41, 66, 0.3);
  }

  .submit-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(26, 41, 66, 0.5);
  }

  .privacy-notice {
    margin-top: 20px;
    font-size: 0.85rem;
    color: #666;
    text-align: center;
  }

  .privacy-notice a {
    color: #daa520;
    text-decoration: none;
  }

  .privacy-notice a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .form-card {
      padding: 30px 20px;
    }
    .form-main-title {
      font-size: 2rem;
    }
    .form-grid {
      grid-template-columns: 1fr;
    }
    .scan-actions {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .form-main-title {
      font-size: 1.8rem;
    }
  }
</style>


{% comment %}
  Gemini Identify for Shopify – include in theme that needs image identification.
  Usage: {% render 'gemini-identify', api_base_url: 'https://your-app.vercel.app' %}
  Or set api_base_url below and include with: {% render 'gemini-identify' %}
{% endcomment %}
{% assign gemini_api_url = api_base_url | default: 'https://YOUR_VERCEL_DOMAIN' %}
<script>
  window.GEMINI_IDENTIFY_API_URL = {{ gemini_api_url | json }};
</script>
{{ 'gemini-identify.js' | asset_url | script_tag }}

{% comment %}
  Snippet: jewelry-ai-form
  AI-powered jewelry recognition form. Include with:
  {% render 'jewelry-ai-form', api_base_url: 'https://your-api.com' %}
{% endcomment %}

<style>
  .jewelry-ai-form * { box-sizing: border-box; }
  .jewelry-ai-form {
    max-width: 640px;
    margin: 0 auto;
    padding: 24px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .jewelry-ai-form .form-group {
    margin-bottom: 20px;
  }
  .jewelry-ai-form label {
    display: block;
    font-weight: 600;
    margin-bottom: 6px;
    color: #1a1a1a;
  }
  .jewelry-ai-form input[type="text"],
  .jewelry-ai-form input[type="file"],
  .jewelry-ai-form textarea,
  .jewelry-ai-form select {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
  }
  .jewelry-ai-form textarea {
    min-height: 100px;
    resize: vertical;
  }
  .jewelry-ai-form .upload-zone {
    border: 2px dashed #ccc;
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    background: #fafafa;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .jewelry-ai-form .upload-zone:hover,
  .jewelry-ai-form .upload-zone.dragover {
    border-color: #1a73e8;
    background: #f0f7ff;
  }
  .jewelry-ai-form .upload-zone input[type="file"] {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    cursor: pointer;
  }
  .jewelry-ai-form .upload-zone-inner { position: relative; }
  .jewelry-ai-form .loading-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.5);
    align-items: center;
    justify-content: center;
    z-index: 9999;
    flex-direction: column;
    gap: 16px;
  }
  .jewelry-ai-form .loading-overlay.visible { display: flex; }
  .jewelry-ai-form .loading-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: jewelry-ai-spin 0.8s linear infinite;
  }
  .jewelry-ai-form .loading-text { color: #fff; font-weight: 600; }
  .jewelry-ai-form .error-msg {
    display: none;
    padding: 12px;
    background: #fde8e8;
    color: #c53030;
    border-radius: 8px;
    margin-bottom: 16px;
  }
  .jewelry-ai-form .error-msg.visible { display: block; }
  .jewelry-ai-form .submit-btn {
    width: 100%;
    padding: 14px 24px;
    background: #1a73e8;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
  }
  .jewelry-ai-form .submit-btn:hover { background: #1557b0; }
  @keyframes jewelry-ai-spin { to { transform: rotate(360deg); } }
</style>

<div class="jewelry-ai-form" id="jewelry-ai-form">
  <div class="loading-overlay" id="jewelry-ai-loading" aria-hidden="true">
    <div class="loading-spinner"></div>
    <span class="loading-text">Analyzing image...</span>
  </div>
  <div class="error-msg" id="jewelry-ai-error" role="alert"></div>

  <form id="jewelry-form" method="post" action="">
    <div class="form-group">
      <label for="jewelry-image">Upload jewelry photo (AI will analyze)</label>
      <div class="upload-zone" id="jewelry-upload-zone">
        <div class="upload-zone-inner">
          <input type="file" id="jewelry-image" name="jewelry_image" accept="image/*" />
          <p style="margin:0; color:#666;">Drop an image here or click to upload</p>
        </div>
      </div>
    </div>

    <div class="form-group">
      <label for="jewelry_type">Jewelry type</label>
      <input type="text" id="jewelry_type" name="jewelry_type" placeholder="e.g. Ring, Necklace" />
    </div>
    <div class="form-group">
      <label for="probable_material">Probable material</label>
      <input type="text" id="probable_material" name="probable_material" placeholder="e.g. Gold, Silver" />
    </div>
    <div class="form-group">
      <label for="possible_stones">Possible stones</label>
      <input type="text" id="possible_stones" name="possible_stones" placeholder="e.g. Diamond, Ruby" />
    </div>
    <div class="form-group">
      <label for="estimated_condition">Estimated condition</label>
      <input type="text" id="estimated_condition" name="estimated_condition" placeholder="e.g. Good, Excellent" />
    </div>
    <div class="form-group">
      <label for="visible_damage">Visible damage</label>
      <input type="text" id="visible_damage" name="visible_damage" placeholder="e.g. None, Light scratching" />
    </div>
    <div class="form-group">
      <label for="style_description">Style description</label>
      <textarea id="style_description" name="style_description" placeholder="Style and design notes"></textarea>
    </div>
    <div class="form-group">
      <label for="short_description_for_listing">Short description for listing</label>
      <textarea id="short_description_for_listing" name="short_description_for_listing" placeholder="Brief listing description"></textarea>
    </div>

    <button type="submit" class="submit-btn">Submit</button>
  </form>
</div>

<script>
(function() {
  var formId = 'jewelry-form';
  var loadingId = 'jewelry-ai-loading';
  var errorId = 'jewelry-ai-error';
  var imageInputId = 'jewelry-image';
  var uploadZoneId = 'jewelry-upload-zone';

  var apiBaseUrl = {{ api_base_url | default: 'https://your-api.com' | json }};
  if (apiBaseUrl.slice(-1) === '/') apiBaseUrl = apiBaseUrl.slice(0, -1);
  var analyzeEndpoint = apiBaseUrl + '/api/analyze-jewelry';

  var form = document.getElementById(formId);
  var loading = document.getElementById(loadingId);
  var errorEl = document.getElementById(errorId);
  var imageInput = document.getElementById(imageInputId);
  var uploadZone = document.getElementById(uploadZoneId);

  function showLoading(show) {
    if (loading) {
      loading.classList.toggle('visible', !!show);
      loading.setAttribute('aria-hidden', !show);
    }
  }
  function showError(msg) {
    if (!errorEl) return;
    errorEl.textContent = msg || '';
    errorEl.classList.toggle('visible', !!msg);
  }

  function fillForm(data) {
    var ids = [
      'jewelry_type', 'probable_material', 'possible_stones',
      'estimated_condition', 'visible_damage', 'style_description',
      'short_description_for_listing'
    ];
    ids.forEach(function(id) {
      var el = document.getElementById(id);
      var val = data[id];
      if (el && val != null && val !== '') el.value = String(val).trim();
    });
  }

  function analyzeImage(base64, mimeType) {
    showError('');
    showLoading(true);
    fetch(analyzeEndpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ image: base64, mimeType: mimeType || 'image/jpeg' })
    })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.error) {
          showError('Image could not be analyzed. Please fill the form manually.');
          return;
        }
        fillForm(data);
      })
      .catch(function(err) {
        console.error('Jewelry AI error:', err);
        showError('Image could not be analyzed. Please fill the form manually.');
      })
      .finally(function() { showLoading(false); });
  }

  function handleFile(file) {
    if (!file || !file.type.startsWith('image/')) return;
    var reader = new FileReader();
    reader.onload = function() {
      var dataUrl = reader.result;
      var base64 = dataUrl.indexOf(',') >= 0 ? dataUrl.split(',')[1] : dataUrl;
      var mime = file.type || 'image/jpeg';
      analyzeImage(base64, mime);
    };
    reader.readAsDataURL(file);
  }

  if (imageInput) {
    imageInput.addEventListener('change', function() {
      var file = this.files && this.files[0];
      if (file) handleFile(file);
    });
  }

  if (uploadZone) {
    uploadZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });
    uploadZone.addEventListener('dragleave', function() {
      uploadZone.classList.remove('dragover');
    });
    uploadZone.addEventListener('drop', function(e) {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      var file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (file) handleFile(file);
    });
  }

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
    });
  }
})();
</script>

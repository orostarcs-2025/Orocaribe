{% comment %}
  Section: Jewelry AI Recognition
  Renders the AI form snippet. Configure the API URL in the theme editor.
{% endcomment %}

<div class="jewelry-ai-section" style="padding: 40px 20px;">
  {% if section.settings.heading != blank %}
    <h2 class="jewelry-ai-heading" style="text-align: center; margin-bottom: 24px;">
      {{ section.settings.heading }}
    </h2>
  {% endif %}
  {% render 'jewelry-ai-form', api_base_url: section.settings.api_base_url %}
</div>

{% schema %}
{
  "name": "Jewelry AI Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Describe your jewelry with AI"
    },
    {
      "type": "text",
      "id": "api_base_url",
      "label": "API base URL",
      "default": "https://your-api.com",
      "info": "Your Node.js API URL (e.g. https://your-app.herokuapp.com). No trailing slash."
    }
  ],
  "presets": [
    { "name": "Jewelry AI Form" }
  ]
}
{% endschema %}
